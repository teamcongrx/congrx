{
  "routes": [
    { "src": "/api/health", "dest": "/api/health" },
    { "src": "/api/seed(.*)", "dest": "/api/seed$1" },
    { "src": "/api/scrape(.*)", "dest": "/api/scrape$1" },
    { "src": "/api/digest(.*)", "dest": "/api/digest$1" },
    { "src": "/api/subscribe(.*)", "dest": "/api/subscribe$1" },
    { "src": "/api/trending(.*)", "dest": "/api/trending$1" },
    { "src": "/api/tweets(.*)", "dest": "/api/tweets$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/api/scrape", "schedule": "0 0 * * *" },
    { "path": "/api/digest", "schedule": "0 8 * * *" }
  ]
}
